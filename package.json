{
  "name": "tetris-multiplayer-monorepo",
  "version": "1.0.0",
  "description": "俄罗斯方块多人对战系统",
  "private": true,
  "scripts": {
    "postinstall": "cd backend && npm install && cd ../frontend && npm install",
    "start": "cd backend && npm start",
    "dev": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "k8s:deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy/deploy.ps1",
    "k8s:undeploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy/undeploy.ps1",
    "lint": "eslint backend/**/*.js frontend/**/*.js",
    "lint:fix": "eslint backend/**/*.js frontend/**/*.js --fix",
    "test": "cd backend && npm test",
    "db:init": "mysql -u root -p < backend/modules/database/schema.sql"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "workspaces": [
    "backend",
    "frontend"
  ]
}
